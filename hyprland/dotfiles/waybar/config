{
    "layer": "top",
    "position": "bottom",
    "mod": "dock",
    "exclusive": true,
    "gtk-layer-shell": true,
    "margin-bottom": 0,
    "passthrough": false,
    "height": 42,
    "modules-left": ["hyprland/workspaces", "wlr/taskbar"],
    "modules-center": [],
    "modules-right": [
        "tray",
        "group/battinfo",
        "pulseaudio",
        "clock",
    ],
    "group/battinfo": {
        "orientation": "vertical",
        "modules": ["group/sysinfo", "battery"]
    },
    "group/sysinfo": {
        "orientation": "horizontal",
        "modules": ["cpu", "memory", "hyprland/language"]
    },
    "hyprland/language": {
        "format": "{}",
        "format-en": "ENG",
        "format-tr": "TR"
    },

    "hyprland/workspaces": {
        "icon-size": 33,
        "spacing": 17,
        "on-scroll-up": "hyprctl dispatch workspace r+2",
        "on-scroll-down": "hyprctl dispatch workspace r0",
        "persistent-workspaces": {
              "*": 5}
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 31,
        "spacing": 4,
        "on-click-middle": "close",
        "tooltip-format": "{title}",
        "ignore-list": [],
        "on-click": "activate",
        "show-app-names": false
    },
    "tray": {
        "icon-size": 19,
        "spacing": 4
    },
    "clock": {
        "format": "      {:%R\n %d.%m.%Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 4,
            "weeks-pos": "right",
            "on-scroll": 2,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#ffead4'><b>{}</b></span>",
                "days": "<span color='#ecc7d9'><b>{}</b></span>",
                "weeks": "<span color='#100ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc67'><b>{}</b></span>",
                "today": "<span color='#ff6700'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "cpu": {
        "format": " {usage:02}%",
        "interval": 2
    },
    "memory": {
        "format": " {used}/{total}GiB",
        "interval": 2
    },
    "battery": {
        "format": " ",
        "format-charging": " ",
        "states": {
            "warning": 25,
            "critical": 10
        }
    },
    "pulseaudio": {
        "max-volume": 151,
        "scroll-step": 11,
        "format": "{icon}",
        "tooltip-format": "{volume}%",
        "format-icons": {
            "format-muted": "",
            "default": [
                "",
                "",
                ""
            ]
        },
        "on-click": "pwvucontrol"
    }
}
